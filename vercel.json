{
  "version": 2,
  "name": "frutos-selectos",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/webhook/(.*)", "destination": "/api/index.js" },
    { "source": "/telegram/(.*)", "destination": "/api/index.js" },
    { "source": "/health", "destination": "/api/index.js" },
    { "source": "/(assets|img)/", "destination": "/$1/" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
