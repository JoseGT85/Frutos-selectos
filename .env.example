# ═══════════════════════════════════════════════════════════════
# DIFRUMARKET — Variables de entorno
# Copiá este archivo como .env y completá los valores
# ═══════════════════════════════════════════════════════════════

# ── Telegram ────────────────────────────────────────────────────
# Token del bot (obtenelo de @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat IDs de admins separados por coma
# Para saber tu ID: escribile a @userinfobot en Telegram
ADMIN_CHAT_IDS=123456789,987654321

# ── Google Sheets ────────────────────────────────────────────────
# URL pública de tu hoja (pubhtml) — la que tiene la columna "remito"
GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/u/7/d/e/2PACX-1vSG8HiC02weCi6VOkBZO_DvChdbviKFEeE2WCJEZ-9awel9e4BqFnuvT8iXdRXNMK6orDFk8eiVibmX/pubhtml?gid=0&single=true

# Margen sobre precio remito (en %)
MARGIN_PCT=30

# TTL del cache de catálogo en milisegundos (default: 15 minutos)
CACHE_TTL_MS=900000

# ── AI Agents ────────────────────────────────────────────────────
# Claude (Anthropic) — PRIMARIO — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-

# Grok (xAI) — SECUNDARIO — https://console.x.ai
GROK_API_KEY=xai-

# Hugging Face — FALLBACK GRATIS — https://huggingface.co/settings/tokens
# Si no tenés key igual funciona (con rate limit)
HF_API_KEY=hf_

# Ollama local — ÚLTIMO RECURSO — instalar en tu servidor
# Ver: https://ollama.ai
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Negocio ──────────────────────────────────────────────────────
BUSINESS_NAME=Frutos Selectos DIFRUMARKET
WA_NUMBER=5491112345678

# ── Servidor Express ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# CORS: en producción poner la URL exacta del frontend React
# Ejemplo: https://tu-dominio.com
CORS_ORIGIN=*

# ── Seguridad ────────────────────────────────────────────────────
# JWT para el panel admin (mínimo 32 caracteres, aleatorio)
JWT_SECRET=cambiame_por_un_string_muy_largo_y_aleatorio_32chars

# Password del admin para /api/admin/login
ADMIN_PASSWORD=cambiame_por_una_password_segura

# IDs de usuarios baneados (separados por coma, opcional)
BANNED_USER_IDS=

# ── Webhook (solo producción) ─────────────────────────────────────
# URL pública donde está corriendo este servidor (con HTTPS)
# WEBHOOK_URL=https://tu-dominio.com
# WEBHOOK_SECRET=otro_string_aleatorio_para_seguridad

# ── Archivos ──────────────────────────────────────────────────────
# Ruta del archivo JSON de la Knowledge Base
KB_FILE=./data/kb.json

# Ruta del archivo JSON de configuración (margen, etc.) — se crea automáticamente
SETTINGS_FILE=./data/settings.json

# Directorio de logs de auditoría
LOG_DIR=./logs

# ── WhatsApp Cloud API (Meta) ────────────────────────────────────────
# Gratis: 1000 conversaciones/mes iniciadas por clientes.
# Configuración en: https://developers.facebook.com/apps → WhatsApp → API Setup
#
# 1. Creá una app en Meta for Developers
# 2. Agregá el producto "WhatsApp" a tu app
# 3. En API Setup, copiá el Phone Number ID y el Access Token
# 4. Configurá el webhook: URL = https://tu-dominio.com/webhook/whatsapp
# 5. Suscribite al campo "messages"

# ID del número de teléfono (lo ves en Meta > WhatsApp > API Setup)
WA_PHONE_NUMBER_ID=123456789012345

# Token de acceso permanente (generalo en Meta > WhatsApp > API Setup > Generate)
WA_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx

# Token para verificar el webhook (vos lo elegís, el mismo que ponés en Meta)
WA_VERIFY_TOKEN=difrumarket_verify_2025

# Número de WhatsApp del negocio (para mostrar en las respuestas del bot)
WA_NUMBER=5491112345678

# ── n8n Integration ──────────────────────────────────────────────────
# Token para autenticar requests desde n8n al webhook /api/admin/n8n/chat
# Generá uno aleatorio: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
N8N_WEBHOOK_TOKEN=tu_token_secreto_aqui

# ── Frontend Vite ─────────────────────────────────────────────────
# URL de Google Sheets (publicada como HTML)
VITE_SHEETS_URL=https://docs.google.com/spreadsheets/.../pubhtml?gid=0&single=true

# URL del backend (para proxy de IA y auth)
VITE_BACKEND_URL=http://localhost:3000

# WhatsApp y negocio (frontend)
VITE_WHATSAPP_NUMBER=5491112345678
VITE_BUSINESS_NAME=Frutos Selectos · DIFRUMARKET
VITE_MARGIN_DEFAULT=30
