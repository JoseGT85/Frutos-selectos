# ─── Frutos Selectos — Variables de Entorno ───────────────────────────
# Copiar este archivo como .env y completar los valores reales.

# Endpoint de la API de productos (Google Sheets Apps Script, Supabase, etc.)
# Dejar vacío para usar datos mock de desarrollo.
VITE_API_ENDPOINT=

# Número de WhatsApp con código de país (sin +, sin espacios)
VITE_WHATSAPP_NUMBER=5491112345678

# Margen de rentabilidad por defecto (porcentaje)
VITE_MARGIN_DEFAULT=30

# Datos del negocio
VITE_BUSINESS_NAME=Frutos Selectos
VITE_BUSINESS_CITY=Buenos Aires

# ─── Automatización (futuro) ─────────────────────────────────────────
# URL del webhook para enviar datos de pedidos al sistema de automatización
VITE_AUTOMATION_WEBHOOK_URL=

# Clave API para autenticar webhooks
VITE_AUTOMATION_API_KEY=
